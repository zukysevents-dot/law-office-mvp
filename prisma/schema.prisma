generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PARTNER
  LAWYER
  TRAINEE
  INTERN
}

enum SubjectType {
  COMPANY
  PERSON
  ENTREPRENEUR
  OTHER
}

enum SubjectRole {
  CLIENT
  COUNTERPARTY
  POTENTIAL_CLIENT
  CONTACT_PERSON
  WITNESS
  REPRESENTATIVE
  STATUTORY_BODY
  OTHER
}

enum FeeType {
  HOURLY
  FLAT
  MIXED
  OTHER
}

enum TaskStatus {
  CREATED
  ACCEPTED
  IN_PROGRESS
  FOR_REVIEW
  WAITING_FOR_CLIENT
  WAITING_FOR_COUNTERPARTY
  POSTPONED
  FILED
  COMPLETED
}

enum TaskPriority {
  LOW
  STANDARD
  HIGH
  CRITICAL
}

enum TaskDeadlineType {
  INTERNAL
  PROCEDURAL
}

enum BillingStatus {
  BILLABLE
  NEEDS_APPROVAL
  INTERNAL_NON_BILLABLE
}

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ADJUSTED
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CaseStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum DashboardWidgetType {
  ACTIVE_TASKS
  OVERDUE_TASKS
  FOR_REVIEW_TASKS
  WAITING_FOR_CLIENT_TASKS
  WAITING_FOR_COUNTERPARTY_TASKS
  MY_TASKS_TABLE
  WORK_LOGS_SUMMARY
  WORK_LOGS_TABLE
  SUBJECTS_TABLE
  PROJECTS_TABLE
  CASES_TABLE
  REFERENCES_TABLE
  RECENT_CONFLICT_CHECKS
  CALENDAR_PREVIEW
}

enum DashboardWidgetSize {
  SMALL
  MEDIUM
  LARGE
  FULL
}

enum NotificationType {
  TASK_CREATED
  TASK_STATUS_CHANGED
  TASK_FOR_REVIEW
  TASK_DEADLINE_SOON
  TASK_FILED_FOLLOWUP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum OrganizationMemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  role            UserRole @default(LAWYER)
  microsoftId     String?  @unique
  passwordHash    String?
  active          Boolean  @default(true)
  // Platform/developer super-admin over all organizations (the /admin panel).
  // Orthogonal to the org-level role; such accounts have no org membership.
  isPlatformAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdSubjectRelations SubjectRelation[]   @relation("SubjectRelationCreatedBy")
  checkedConflictChecks   ConflictCheck[]     @relation("ConflictCheckCheckedBy")
  responsibleProjects     Project[]           @relation("ProjectResponsibleUser")
  responsibleCases        Case[]              @relation("CaseResponsibleUser")
  createdTasks            Task[]              @relation("TaskCreatedBy")
  assignedTasks           Task[]              @relation("TaskAssignedTo")
  responsibleTasks        Task[]              @relation("TaskResponsibleUser")
  changedTaskStatuses     TaskStatusHistory[] @relation("TaskStatusChangedBy")
  taskComments            TaskComment[]       @relation("TaskCommentAuthor")
  workLogs                WorkLog[]
  auditLogs               AuditLog[]          @relation("AuditLogChangedBy")
  dashboardWidgets        DashboardWidget[]
  tableViewPreferences    TableViewPreference[]
  notificationPreference  NotificationPreference?
  notifications           Notification[]      @relation("NotificationRecipient")
  memberships             OrganizationMember[]

  @@map("users")
}

model Subject {
  id               String      @id @default(cuid())
  organizationId   String
  type             SubjectType @default(COMPANY)
  name             String
  ico              String?     @unique
  dic              String?
  email            String?
  address          String?
  legalForm        String?
  statutoryBody    String?
  status           String      @default("ACTIVE")
  insolvencyStatus String?
  riskFlag         Boolean     @default(false)
  internalNote     String?
  legalServicesContractUrl String?
  sharepointUrl    String?
  feeType          FeeType?
  hourlyRate       Decimal?    @db.Decimal(12, 2)
  flatFee          Decimal?    @db.Decimal(12, 2)
  feeNote          String?
  aresVerifiedAt   DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  archivedAt       DateTime?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  relations      SubjectRelation[]
  conflictChecks ConflictCheck[]
  mainProjects   Project[]         @relation("ProjectMainSubject")
  references     Reference[]
  workLogs       WorkLog[]

  @@index([organizationId])
  @@index([name])
  @@index([ico])
  @@index([riskFlag])
  @@map("subjects")
}

model SubjectRelation {
  id           String      @id @default(cuid())
  subjectId    String
  relationType String
  role         SubjectRole
  projectId    String?
  caseId       String?
  note         String?
  createdById  String?
  createdAt    DateTime    @default(now())

  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("SubjectRelationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([subjectId])
  @@index([projectId])
  @@index([caseId])
  @@index([role])
  @@map("subjectRelations")
}

model ConflictCheck {
  id             String   @id @default(cuid())
  organizationId String
  searchedQuery  String
  subjectId      String?
  resultStatus   String
  checkedById    String?
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subject      Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  checkedBy    User?        @relation("ConflictCheckCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([searchedQuery])
  @@index([subjectId])
  @@index([checkedById])
  @@map("conflictChecks")
}

model Project {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  mainSubjectId     String
  responsibleUserId String?
  status            ProjectStatus @default(ACTIVE)
  hourlyRate        Decimal?      @db.Decimal(12, 2)
  sharepointUrl     String?
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  archivedAt        DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  mainSubject      Subject           @relation("ProjectMainSubject", fields: [mainSubjectId], references: [id], onDelete: Restrict)
  responsibleUser  User?             @relation("ProjectResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  cases            Case[]
  tasks            Task[]
  subjectRelations SubjectRelation[]
  references       Reference[]
  workLogs         WorkLog[]

  @@index([organizationId])
  @@index([mainSubjectId])
  @@index([responsibleUserId])
  @@index([status])
  @@map("projects")
}

model Case {
  id                String     @id @default(cuid())
  organizationId    String
  projectId         String
  name              String
  fileNumber        String?
  responsibleUserId String?
  status            CaseStatus @default(ACTIVE)
  hourlyRate        Decimal?   @db.Decimal(12, 2)
  sharepointUrl     String?
  note              String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  archivedAt        DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  responsibleUser  User?             @relation("CaseResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  tasks            Task[]
  subjectRelations SubjectRelation[]
  references       Reference[]
  workLogs         WorkLog[]

  @@unique([projectId, fileNumber])
  @@index([organizationId])
  @@index([projectId])
  @@index([responsibleUserId])
  @@index([status])
  @@map("cases")
}

model Task {
  id                  String       @id @default(cuid())
  organizationId      String
  title               String
  projectId           String?
  caseId              String?
  createdById         String?
  assignedToId        String?
  responsibleUserId   String?
  status              TaskStatus   @default(CREATED)
  priority            TaskPriority @default(STANDARD)
  deadlineType        TaskDeadlineType @default(INTERNAL)
  shortDescription    String?
  detailedDescription String?
  sharepointUrl       String?
  startDate           DateTime?
  deadline            DateTime?
  completedAt         DateTime?
  archivedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project       Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  case          Case?               @relation(fields: [caseId], references: [id], onDelete: SetNull)
  createdBy     User?               @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo    User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  responsibleUser User?              @relation("TaskResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  statusHistory TaskStatusHistory[]
  comments      TaskComment[]
  workLogs      WorkLog[]

  @@index([organizationId])
  @@index([projectId])
  @@index([caseId])
  @@index([assignedToId])
  @@index([responsibleUserId])
  @@index([status])
  @@index([deadlineType])
  @@index([deadline])
  @@map("tasks")
}

model TaskStatusHistory {
  id          String     @id @default(cuid())
  taskId      String
  oldStatus   TaskStatus
  newStatus   TaskStatus
  changedById String?
  note        String?
  createdAt   DateTime   @default(now())

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User? @relation("TaskStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([changedById])
  @@map("taskStatusHistory")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String?
  comment   String
  createdAt DateTime @default(now())

  task   Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User? @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
  @@map("taskComments")
}

model WorkLog {
  id             String         @id @default(cuid())
  organizationId String
  subjectId      String?
  projectId      String?
  caseId         String?
  taskId         String?
  userId         String?
  workDate       DateTime
  hours          Decimal        @db.Decimal(8, 2)
  hourlyRate     Decimal?       @db.Decimal(12, 2)
  amountCzk      Decimal?       @db.Decimal(12, 2)
  description    String?
  billingStatus  BillingStatus  @default(BILLABLE)
  approvalStatus ApprovalStatus @default(DRAFT)
  legalArea      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  case    Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([subjectId])
  @@index([projectId])
  @@index([caseId])
  @@index([taskId])
  @@index([userId])
  @@index([workDate])
  @@index([archivedAt])
  @@map("workLogs")
}

model Reference {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  projectId      String?
  caseId      String?
  subjectId   String?
  legalArea   String?
  valueCzk    Decimal? @db.Decimal(14, 2)
  startDate   DateTime?
  endDate     DateTime?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archivedAt  DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  case    Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([caseId])
  @@index([subjectId])
  @@index([legalArea])
  @@index([valueCzk])
  @@index([endDate])
  @@index([archivedAt])
  @@map("references")
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  oldValue    Json?
  newValue    Json?
  changedById String?
  createdAt   DateTime @default(now())

  changedBy User? @relation("AuditLogChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([changedById])
  @@index([createdAt])
  @@map("auditLogs")
}

model DashboardWidget {
  id        String              @id @default(cuid())
  // Nullable: these are per-user UI prefs, already isolated by userId (a user
  // belongs to one org). ponytail: column present for spec/future multi-org, not
  // required for any query — no create-site churn.
  organizationId String?
  userId    String
  type      DashboardWidgetType
  title     String
  position  Int
  size      DashboardWidgetSize @default(MEDIUM)
  visible   Boolean             @default(true)
  config    Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, position])
  @@index([userId, visible])
  @@map("dashboardWidgets")
}

model TableViewPreference {
  id             String   @id @default(cuid())
  // Nullable for the same reason as DashboardWidget.organizationId — userId
  // already isolates per-user UI prefs. ponytail: spec/future, no query churn.
  organizationId String?
  userId         String
  tableKey       String
  visibleColumns Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
  @@index([organizationId])
  @@index([userId])
  @@index([tableKey])
  @@map("tableViewPreferences")
}

model NotificationPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  emailEnabled           Boolean  @default(true)
  taskCreatedEmail       Boolean  @default(true)
  taskStatusChangedEmail Boolean  @default(true)
  taskForReviewEmail     Boolean  @default(true)
  taskDeadlineSoonEmail  Boolean  @default(true)
  taskFiledFollowupEmail Boolean  @default(true)
  deadlineReminderDays   Int      @default(1)
  filedFollowupDays      Int      @default(5)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificationPreferences")
}

model Notification {
  id              String             @id @default(cuid())
  recipientUserId String
  type            NotificationType
  status          NotificationStatus @default(PENDING)
  subject         String
  body            String
  entityType      String?
  entityId        String?
  dedupeKey       String?            @unique
  emailTo         String?
  sentAt          DateTime?
  attempts        Int                @default(0)
  lastError       String?
  lockedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  recipient User @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, status])
  @@index([status, lockedAt])
  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("notifications")
}

model Organization {
  id                  String             @id @default(cuid())
  name                String
  slug                String             @unique
  seatLimit           Int                @default(0)
  status              OrganizationStatus @default(ACTIVE)
  // Optional, unused this phase — email domain is NOT a join restriction.
  allowedEmailDomains Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  archivedAt          DateTime?

  members              OrganizationMember[]
  joinCodes            OrganizationJoinCode[]
  subjects             Subject[]
  projects             Project[]
  cases                Case[]
  tasks                Task[]
  workLogs             WorkLog[]
  references           Reference[]
  conflictChecks       ConflictCheck[]
  dashboardWidgets     DashboardWidget[]
  tableViewPreferences TableViewPreference[]

  @@index([status])
  @@map("organizations")
}

model OrganizationJoinCode {
  id              String    @id @default(cuid())
  organizationId  String
  // Only the keyed hash of the code is stored — never the plaintext.
  codeHash        String    @unique
  label           String
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  revokedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organizationJoinCodes")
}

model OrganizationMember {
  id               String                   @id @default(cuid())
  organizationId   String
  userId           String
  role             UserRole                 @default(LAWYER)
  status           OrganizationMemberStatus @default(ACTIVE)
  joinedAt         DateTime                 @default(now())
  approvedAt       DateTime?
  approvedByUserId String?
  deactivatedAt    DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organizationMembers")
}
