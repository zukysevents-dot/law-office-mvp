# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Dependencies ----------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js build output --------------------------------------------------
/.next/
/out/
/build/
*.tsbuildinfo
# Auto-generated by Next on dev/build; should not be committed.
next-env.d.ts

# --- Prisma ----------------------------------------------------------------
# Generated client (custom output dir). Regenerated automatically by the
# postinstall / predev / prebuild `prisma generate` scripts, so it is not
# committed. (Note: CLAUDE.md still says this is committed — reconcile if the
# intent changes.)
/src/generated/prisma/

# --- Testing / coverage ----------------------------------------------------
/coverage/

# --- Environment variables -------------------------------------------------
# Ignore every .env file except the tracked example.
.env*
!.env.example

# --- Logs & debug ----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server*.log

# --- Deployment ------------------------------------------------------------
.vercel

# --- Design-system sync (claude.ai/design) ---------------------------------
# Staged converter scripts, compiled bundles and capture output. The durable
# inputs under .design-sync/ (config.json, conventions.md, lib-src/, previews/)
# ARE meant to be committed — only its transient/cache subdirs are ignored.
/.ds-sync/
/ds-bundle/
/dist/
.design-sync/.cache/
.design-sync/node_modules/
.design-sync/learnings/

# --- Claude Code (local, machine-specific) ---------------------------------
.claude/settings.local.json
.claude/launch.json

# --- Editors & OS ----------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
*~
*.pem

# Playwright MCP smoke-test artifacts
.playwright-mcp/
