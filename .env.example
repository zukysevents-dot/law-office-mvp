# Local development database. Matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/law_office_mvp?schema=public"

# Base URL used in notification links.
APP_BASE_URL="http://127.0.0.1:3001"

# E-mail notifications. Keep disabled locally unless SMTP is configured.
EMAIL_NOTIFICATIONS_ENABLED="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="syndikat.legal <no-reply@syndikat.legal>"
SMTP_SECURE="false"

# Bearer token required by POST /api/internal/notifications/run.
# Use a strong random value (>= 32 chars) in production.
NOTIFICATION_RUN_SECRET="change-me-locally"

# Secret used to sign session cookies (per-user login). REQUIRED in production:
# must be a random value of at least 32 characters, or the app refuses to start.
# In development a built-in insecure fallback is used if this is empty.
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=""

# Seed-only: initial password set for the demo users by `npm run db:seed`.
# Defaults to "demo1234" if empty. Not read by the running app.
SEED_USER_PASSWORD=""

# --- Microsoft 365 / SharePoint (Fáze 2I) ---------------------------------
# Everything below is OPTIONAL. With no values set, the app behaves exactly as
# before; these features degrade gracefully (like email does).

# SharePoint folder URL convention (no API needed). When SHAREPOINT_SITE_URL is
# set, "Vytvořit složku v SharePointu" derives + stores a folder URL per
# subject/project/case. SHAREPOINT_LIBRARY must be the document library's URL
# path segment (NOT its display name) so the link resolves, e.g. "Dokumenty" or
# "Shared Documents"; it may be a nested path like "Shared Documents/Spisy".
# Defaults to "Dokumenty".
SHAREPOINT_SITE_URL=""
SHAREPOINT_LIBRARY="Dokumenty"

# Outlook / Microsoft 365 e-mail: no new code — just point the existing SMTP
# settings above at Microsoft 365 to route notification e-mails through Outlook:
#   SMTP_HOST="smtp.office365.com"
#   SMTP_PORT="587"
#   SMTP_SECURE="false"
#   SMTP_USER="you@yourtenant.onmicrosoft.com"
#   SMTP_PASSWORD="<app password>"
#   SMTP_FROM="Vaše jméno <you@yourtenant.onmicrosoft.com>"

# --- ARES / rejstříky (Fáze 2J) -------------------------------------------
# The Czech ARES REST API is public and needs no credentials. Both values are
# OPTIONAL: leave them as-is in normal use.
# ARES_BASE_URL only overrides the endpoint (e.g. for a proxy/mirror); empty
# uses the official https://ares.gov.cz/ekonomicke-subjekty-v-be/rest.
ARES_BASE_URL=""
# Kill-switch for "Načíst z ARES" / "Ověřit přes ARES". Set to "false" to disable.
ARES_LOOKUP_ENABLED="true"

# --- F2 Datové schránky (DATA_BOXES) ---
# Šifrovací klíč pro citlivá data at-rest (přihlašovací údaje k DS). Povinné, když
# je modul DATA_BOXES aktivní. 32 bajtů v base64: `openssl rand -base64 32`
# (nebo `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`).
DATA_ENCRYPTION_KEY=""
# Integrace ISDS — provider zatím nerozhodnut (oficiální API vs partner). MVP běží
# na stub klientovi bez sítě; ponechte false, dokud nebude reálné napojení.
ISDS_ENABLED="false"
